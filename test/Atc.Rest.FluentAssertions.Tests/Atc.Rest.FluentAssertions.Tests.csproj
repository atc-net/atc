<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <!-- This project specifically targets FluentAssertions (the library under test), so opt out of the
       solution-wide AwesomeAssertions global using and use FluentAssertions instead. -->
  <ItemGroup>
    <Using Remove="AwesomeAssertions" />
    <Using Include="FluentAssertions" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Atc.Rest.FluentAssertions\Atc.Rest.FluentAssertions.csproj" />
    <ProjectReference Include="..\..\src\Atc.XUnit\Atc.XUnit.csproj" />
  </ItemGroup>

</Project>